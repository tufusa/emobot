{
  "name": "emobot",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "deploy": "wrangler deploy --minify src/index.ts",
    "format": "biome format --write src",
    "lint": "biome lint --write src",
    "typecheck": "tsc --noEmit",
